{
  "entities": {
    "User": {
      "title": "User",
      "description": "An agent using the portal.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "description": "User email address" },
        "name": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "description": "User role, e.g., 'agent'" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Upload": {
      "title": "Upload",
      "description": "A record of a raw file uploaded by an agent.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "ID of the agent who uploaded" },
        "filename": { "type": "string", "description": "Name of the uploaded file" },
        "totalAmount": { "type": "number", "description": "Total amount in the file" },
        "totalAccounts": { "type": "number", "description": "Total number of accounts" },
        "status": { "type": "string", "description": "Status of the upload, e.g., 'processed'" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "filename", "totalAmount", "totalAccounts", "status", "createdAt"]
    },
    "Batch": {
      "title": "Batch",
      "description": "A lot of up to ₹20,000 for the Python script to process.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "ID of the agent who owns this batch" },
        "uploadId": { "type": "string", "description": "ID of the upload this batch belongs to" },
        "totalAmount": { "type": "number", "description": "Total amount in this batch (<= 20000)" },
        "accountCount": { "type": "number", "description": "Number of accounts in this batch" },
        "status": { "type": "string", "description": "Status, e.g., 'pending', 'processing', 'completed', 'failed'" },
        "referenceNumber": { "type": "string", "description": "The reference number generated by the DOP portal" },
        "batchNumber": { "type": "number", "description": "The sequential number of the batch" },
        "accounts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "accountNo": { "type": "string" },
              "amount": { "type": "number" }
            },
            "required": ["accountNo", "amount"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "uploadId", "totalAmount", "accountCount", "status", "accounts", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores agent profiles."
    },
    "/uploads/{uploadId}": {
      "schema": { "$ref": "#/entities/Upload" },
      "description": "Stores metadata about uploaded files."
    },
    "/batches/{batchId}": {
      "schema": { "$ref": "#/entities/Batch" },
      "description": "Stores the ₹20,000 lots."
    }
  }
}
